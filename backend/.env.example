# Copy to .env and adjust paths for your machine (Windows: use forward slashes or escaped backslashes)
DATABASE_URL=sqlite:///./data/invoices.db
UPLOAD_DIR=./uploads
ARTIFACTS_DIR=./artifacts
TESSERACT_CMD=
# Optional: full path to tesseract.exe on Windows, e.g. C:/Program Files/Tesseract-OCR/tesseract.exe
TESSDATA_PREFIX=
# Optional: directory containing tessdata (or tessdata itself). Example:
#   TESSDATA_PREFIX=C:/Program Files/Tesseract-OCR
# or
#   TESSDATA_PREFIX=C:/Program Files/Tesseract-OCR/tessdata
# Tabular rows merged into IsolationForest training (see README)
TRAINING_DATASET_PATH=./data/training/invoice_training_features.csv
# Invoice images for bulk import (comma-separated dirs)
TRAINING_IMAGE_DIRS=./data/batch_1,./data/batch_2,./data/batch_3
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENABLE_NER=false
SPACY_MODEL=en_core_web_sm
LOG_LEVEL=INFO
